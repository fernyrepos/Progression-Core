<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Progression: Agriculture</li>
		</mods>
			<match Class="PatchOperationSequence">
				<operations>
					<li Class="PatchOperationAdd">
						<xpath>Defs/ThingDef[defName="SeedPackingCraftingSpot"]</xpath>
						<value>
							<researchPrerequisites>
								<li>VFET_Agriculture</li>
							</researchPrerequisites>
						</value>
					</li>
					<li Class="PatchOperationAdd">
						<xpath>Defs/ThingDef[defName="SeedPackingBench"]</xpath>
						<value>
							<researchPrerequisites>
								<li>VFET_Culture</li>
							</researchPrerequisites>
						</value>
					</li>


					<li Class="PatchOperationConditional">
						<xpath>/Defs/ResearchProjectDef[defName="Ferny_SeedPackingBench"]/prerequisites</xpath>
							<match Class="PatchOperationAdd">
							<xpath>/Defs/ResearchProjectDef[defName="Ferny_SeedPackingBench"]/prerequisites</xpath>
								<value>
									<li>VFET_Agriculture</li>
								</value>
							</match>
							<nomatch Class="PatchOperationAdd">
							<xpath>/Defs/ResearchProjectDef[defName="Ferny_SeedPackingBench"]</xpath>
								<value>
									<prerequisites>
										<li>VFET_Agriculture</li>
									</prerequisites>
								</value>
							</nomatch>
					</li>



				</operations>
		</match>
	</Operation>
</Patch>